{
  "name": "repo-launch-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for repository launch materials and readiness checks",
  "type": "module",
  "bin": {
    "repo-launch-skill": "./bin/repo-launch-skill.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/repo-launch-skill.js plan --manifest fixtures/manifest.json --readme fixtures/README.sample.md --format md",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "launch",
    "open-source",
    "release-candidate",
    "demo-script"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repo-launch-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repo-launch-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/repo-launch-skill#readme",
  "files": [
    "src",
    "bin",
    "fixtures",
    "examples",
    "docs",
    "SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ]
}
